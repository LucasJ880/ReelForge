# ====== 必填 ======

# Neon Postgres
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# OpenAI（文案生成）
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# NextAuth（JWT 密钥，生成: openssl rand -hex 32）
AUTH_SECRET=

# Vercel Blob（视频/音频/图片存储）
BLOB_READ_WRITE_TOKEN=your-vercel-blob-rw-token

# 应用公网地址
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ====== 可选 ======

# Pro 通道：即梦 / 火山方舟 Seedance
# 未填时走 mock（不消耗真实 Token）
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_VIDEO_MODEL=doubao-seedance-2-0-260128

# Free 通道：Pexels（免费申请 https://www.pexels.com/api/）
# 未填时走 mock 公开样片
PEXELS_API_KEY=

# 测试开关：强制所有视频走 mock，不消耗任何真实 AI 额度
# 建议在 Vercel Preview 环境设为 true 做烟雾测试
VIDEO_ENGINE_MOCK=false

# Cron（如使用 Vercel Cron）
CRON_SECRET=
