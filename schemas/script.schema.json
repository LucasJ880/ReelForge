{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "reelforge://schemas/script",
  "title": "Video Script",
  "description": "视频脚本结构",
  "type": "object",
  "properties": {
    "script_id": {"type": "string"},
    "project_id": {"type": "string"},
    "brief_id": {"type": "string"},
    "title": {"type": "string", "description": "视频标题"},
    "hook": {"type": "string", "description": "开头吸引语（前3秒）"},
    "body": {"type": "string", "description": "正文内容"},
    "cta": {"type": "string", "description": "行动号召"},
    "voiceover_text": {"type": "string", "description": "完整口播文案"},
    "subtitle_text": {"type": "string", "description": "字幕文本"},
    "visual_directions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": {"type": "string", "description": "时间点，如 00:00-00:03"},
          "visual": {"type": "string", "description": "画面描述"},
          "text_overlay": {"type": "string"},
          "transition": {"type": "string"}
        },
        "required": ["timestamp", "visual"]
      }
    },
    "music_style": {"type": "string"},
    "duration_seconds": {"type": "integer"},
    "version": {"type": "integer", "default": 1},
    "status": {"type": "string", "enum": ["draft", "review", "approved", "rejected"]},
    "reviewer_notes": {"type": "string"},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"}
  },
  "required": ["script_id", "project_id", "title", "hook", "body", "voiceover_text", "duration_seconds"]
}
