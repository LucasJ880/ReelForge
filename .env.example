# ====== 必填 ======

# Neon Postgres
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# OpenAI（文案/调研/打分/蒸馏的 LLM 管线）
OPENAI_API_KEY=sk-your-openai-api-key-here
# 旧版兜底变量；只对未单独配置 tier 的阶段生效。建议改用下面的分层变量。
OPENAI_MODEL=gpt-4o-mini

# === OpenAI 模型分层（2026-05 起强烈建议） ===
# creative：客户能看到的创意/脚本/视频 prompt → 必须用强模型
OPENAI_CREATIVE_MODEL=gpt-4.1
# qa：AI 初审 / Reviewer Agent → 推理能力优先
OPENAI_QA_MODEL=gpt-4.1-mini
# fast：分类 / 抽取 / 轻量补字段
OPENAI_FAST_MODEL=gpt-4o-mini
# research：市场调研结构化压缩
OPENAI_RESEARCH_MODEL=gpt-4o-mini
# vision：图像分析（暂只 gpt-4o 支持 JSON + image，谨慎覆盖）
OPENAI_VISION_MODEL=gpt-4o

# NextAuth（JWT 密钥，生成: openssl rand -hex 32）
AUTH_SECRET=

# Vercel Blob（视频/图片/CSV 存储）
BLOB_READ_WRITE_TOKEN=your-vercel-blob-rw-token

# 应用公网地址
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ====== 视频生成：即梦 / 火山方舟 Seedance ======
# 未填时走 mock（不消耗真实 Token，用于开发测试）
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# T2V 模型
ARK_VIDEO_MODEL=doubao-seedance-2-0-260128
# I2V 模型（与 T2V 可相同或不同，留空则复用 ARK_VIDEO_MODEL）
ARK_VIDEO_I2V_MODEL=

# 强制所有视频走 mock（跳过真实 AI 额度）
VIDEO_ENGINE_MOCK=false
# 视频生成「用时较长」阈值（分钟）；超过后 UI 提示用户可刷新/重试，但不会自动判失败
SEEDANCE_TIMEOUT_MIN=15
# 连续 N 次 Provider 状态查询失败后 → VideoJob 标记 FAILED 并提供重试入口
SEEDANCE_POLL_ERROR_THRESHOLD=3
# 可选：Seedance webhook 回调地址（公网可达）。未填则只走轮询
# 例：https://your-app.vercel.app/api/webhooks/seedance
SEEDANCE_CALLBACK_URL=

# ====== Cron & 初始化 ======
# Cron 密钥（Vercel Cron 调用时验证）
CRON_SECRET=

# 首次部署种子管理员账号（只有首次 seed 生效）
SEED_ADMIN_EMAIL=admin@aivora.internal
SEED_ADMIN_PASSWORD=

# ====== 真实市场调研：Apify TikTok Scraper ======
# 未填时 discovery-service 仅走 LLM 常识模式
# 已填时会真实抓 TikTok 高赞视频 + 热评，喂给 LLM 作为上下文 → 更可信的 pain_points
APIFY_TOKEN=
# 可选 Actor 覆盖（默认 clockworks/tiktok-scraper + clockworks/tiktok-comments-scraper）
APIFY_TIKTOK_SEARCH_ACTOR=
APIFY_TIKTOK_VIDEO_ACTOR=
APIFY_TIKTOK_COMMENTS_ACTOR=

# ====== TikTok OAuth（V2 全自动发布预留；MVP 半自动不使用） ======
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ====== 客户 Demo：数字人 Provider（默认 mock；拿到 HeyGen key 后切换） ======
DIGITAL_HUMAN_PROVIDER=mock
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=

# ====== 可选：I2V 抠图预处理（V2） ======
# 若填写，则 I2V 参考图上传后自动走抠图/白底处理
REMOVE_BG_API_KEY=
