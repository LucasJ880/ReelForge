{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "reelforge://schemas/delivery_record",
  "title": "Delivery Record",
  "description": "交付记录",
  "type": "object",
  "properties": {
    "delivery_id": {"type": "string"},
    "project_id": {"type": "string"},
    "video_job_id": {"type": "string"},
    "qa_report_id": {"type": "string"},
    "delivery_format": {"type": "string", "enum": ["mp4", "mov", "webm"]},
    "delivery_url": {"type": "string"},
    "delivery_method": {"type": "string", "enum": ["download_link", "cloud_share", "direct_upload"]},
    "client_feedback": {
      "type": "object",
      "properties": {
        "rating": {"type": "integer", "minimum": 1, "maximum": 5},
        "comment": {"type": "string"},
        "revision_requested": {"type": "boolean"}
      }
    },
    "performance_data": {
      "type": "object",
      "properties": {
        "views": {"type": "integer"},
        "likes": {"type": "integer"},
        "shares": {"type": "integer"},
        "comments": {"type": "integer"},
        "watch_time_seconds": {"type": "number"},
        "engagement_rate": {"type": "number"},
        "collected_at": {"type": "string", "format": "date-time"}
      }
    },
    "cost_summary": {
      "type": "object",
      "properties": {
        "llm_cost_cents": {"type": "integer"},
        "video_gen_cost_cents": {"type": "integer"},
        "total_cost_cents": {"type": "integer"},
        "revision_count": {"type": "integer"}
      }
    },
    "status": {"type": "string", "enum": ["preparing", "delivered", "accepted", "revision_requested"]},
    "delivered_at": {"type": "string", "format": "date-time"},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"}
  },
  "required": ["delivery_id", "project_id", "video_job_id", "status"]
}
