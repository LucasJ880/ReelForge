{
  "name": "aivora",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "predev": "tsx scripts/check-real-mode.ts || true",
    "dev": "next dev",
    "dev:mock": "LLM_FORCE_MOCK=true VIDEO_ENGINE_MOCK=true IMAGE_ENGINE_MOCK=true VIDEO_ENGINE_MOCK_LATENCY_MS=0 npm run dev",
    "walkthrough:mock": "tsx scripts/mock-walkthrough-harness.ts",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e .env.local -- prisma migrate deploy",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "postinstall": "prisma generate",
    "db:seed": "dotenv -e .env.local -- tsx prisma/seed.ts",
    "db:seed:creative-cards": "dotenv -e .env.local -- tsx scripts/seed-creative-evidence-cards.ts",
    "demo:generate:walkthrough": "tsx scripts/generate-real-footage-walkthrough-video.ts",
    "demo:check:walkthrough": "tsx scripts/check-real-footage-walkthrough-video.ts",
    "demo:stitch:walkthrough": "tsx scripts/stitch-real-footage-walkthrough-video.ts",
    "codemap:build": "tsx scripts/build-codemap.ts",
    "context:find": "tsx scripts/context-router.ts",
    "context:video": "tsx scripts/context-router.ts video generation ffmpeg demo blob",
    "demo:mock-business-flow": "tsx scripts/demo-mock-business-flow.ts",
    "demo:brand-overlay": "tsx scripts/demo-brand-overlay.ts",
    "demo:sunny-investor": "tsx scripts/sunny-shutter-investor-demo.ts",
    "demo:sunny-investor:v21": "tsx scripts/sunny-shutter-investor-demo-v21.ts",
    "demo:sunny-investor:v21:submit": "tsx scripts/sunny-shutter-investor-demo-v21.ts --phase=submit",
    "demo:sunny-investor:v21:wait": "tsx scripts/sunny-shutter-investor-demo-v21.ts --phase=wait",
    "demo:sunny-investor:v21:assemble": "tsx scripts/sunny-shutter-investor-demo-v21.ts --phase=assemble",
    "demo:sunny-investor:v21:publish": "tsx scripts/sunny-shutter-investor-demo-v21.ts --phase=publish",
    "demo:sunny-investor:v21:add-bgm": "tsx scripts/sunny-shutter-investor-demo-v21.ts --phase=add-bgm",
    "demo:sunny-investor:v21:resume": "bash scripts/sunny-shutter-investor-demo-v21-resume.sh",
    "e2e:phase4:mock": "node --import tsx --test tests/personal-status-customer-safe.test.ts tests/personal-customer-strings.test.ts tests/unified-creative-strategist.test.ts tests/seedance-privacy-fallback.test.ts",
    "mode:check": "tsx scripts/check-real-mode.ts",
    "mode:check:strict": "tsx scripts/check-real-mode.ts -- --strict",
    "roadmap": "tsx scripts/roadmap.ts",
    "test": "node --import tsx --test tests/**/*.test.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@prisma/client": "^6.19.3",
    "@vercel/blob": "^2.3.3",
    "apify-client": "^2.23.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "openai": "^6.33.0",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.2",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
