generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  DRAFT
  CONTENT_GENERATED
  VIDEO_GENERATING
  VIDEO_FAILED
  VIDEO_READY
  DONE
}

enum VideoJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum BatchStatus {
  PENDING
  RUNNING
  PAUSED
  COMPLETED
  FAILED
}

model Batch {
  id                String      @id @default(cuid())
  name              String
  status            BatchStatus @default(PENDING)
  totalCount        Int         @default(0)
  completedCount    Int         @default(0)
  failedCount       Int         @default(0)
  videoParams       Json?
  concurrency       Int         @default(2)
  autoGenerateVideo Boolean     @default(true)
  errorMessage      String?
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  projects Project[]

  @@index([status])
  @@index([createdAt(sort: Desc)])
}

model Project {
  id               String        @id @default(cuid())
  keyword          String
  category         String?
  status           ProjectStatus @default(DRAFT)
  errorMessage     String?
  retryCount       Int           @default(0)
  batchId          String?
  batchIndex       Int?
  /// 是否在公共画廊展示；默认公开，ADMIN 可手动私有化
  isPublic         Boolean       @default(true)
  /// 自由文本：用户描述自己的品牌/产品/背景信息（可选）
  brandDescription String?
  /// 内容语气：auto | promo | narrative | educational | vlog | news | humor | cinematic | testimonial
  tone             String?       @default("auto")
  /// 脚本/配音语言：auto | en | zh | ja | ko | es | fr | de
  language         String?       @default("auto")
  imageUrls        String[]
  primaryImageUrl  String?
  userVideoAssets  String[]      @default([])

  // --- Brand Lock 品牌保真合成配置 ---
  /// 单独上传的品牌 Logo (PNG 优先，透明背景最佳)
  logoUrl           String?
  /// 是否启用 Brand Lock 合成
  brandLockEnabled  Boolean  @default(true)
  /// 合成模板：none | corner_watermark | intro_outro | full_package
  brandLockTemplate String   @default("corner_watermark")
  /// 角标水印位置：bottom-right | bottom-left | top-right | top-left
  brandLockPosition String   @default("bottom-right")
  /// 水印不透明度 0-100
  brandLockOpacity  Int      @default(85)
  /// 叠加的 Slogan / 品牌文字 (full_package 使用)
  brandLockSlogan   String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  batch       Batch?       @relation(fields: [batchId], references: [id])
  contentPlan ContentPlan?
  videoJob    VideoJob?

  @@index([status])
  @@index([category])
  @@index([batchId])
  @@index([isPublic, status])
  @@index([createdAt(sort: Desc)])
}

model ContentPlan {
  id               String   @id @default(cuid())
  projectId        String   @unique
  script           String
  videoPrompt      String
  videoPromptPart2 String?
  caption          String
  hashtags         String[]
  contentAngles    Json
  modelUsed        String
  tokenUsage       Json?
  createdAt        DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model VideoJob {
  id               String         @id @default(cuid())
  projectId        String         @unique
  provider         String         @default("jimeng")
  /// 历史字段；当前仅使用 "pro"（Seedance）。保留以兼容旧数据。
  channel          String         @default("pro")
  providerJobId    String?
  providerJobId2   String?
  status           VideoJobStatus @default(PENDING)
  videoUrl         String?
  videoUrl2        String?
  stitchedVideoUrl String?
  /// Brand Lock 后的最终品牌版视频（硬叠加 logo/产品/slogan 后的成品）
  brandedVideoUrl  String?
  thumbnailUrl     String?
  duration         Int            @default(15)
  resolution       String         @default("1080p")
  ratio            String         @default("9:16")
  segment          Int?
  lastFrameUrl     String?
  /// 多变体: [{ jobId, videoUrl, thumbnailUrl, status, selected? }]
  variants         Json?
  selectedVariant  Int            @default(0)
  /// 历史字段：旧 Free 通道的素材 manifest；新流程不再使用
  manifest         Json?
  errorMessage     String?
  retryCount       Int            @default(0)
  createdAt        DateTime       @default(now())
  completedAt      DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

enum UserRole {
  ADMIN
  USER
}

enum UserPlanTier {
  FREE
  PRO
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  hashedPassword String
  name           String?
  role           UserRole     @default(USER)

  // --- 订阅 / 付费计划 ---
  /// 当前套餐。ADMIN 始终视同 PRO，不以该字段为准
  planTier       UserPlanTier @default(FREE)
  /// 到期时间；当前时间晚于该值则自动降回 FREE（纯查询判断，不需要 cron）
  planExpiresAt  DateTime?
  /// 本次订阅由哪个 ADMIN 手动开通；未来 Stripe/Creem 回写时填系统标识
  planGrantedBy  String?
  /// 本次订阅开通时间
  planGrantedAt  DateTime?
  /// 来源：none / admin-manual / stripe / creem（V2 用）
  planSource     String       @default("none")

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([planTier, planExpiresAt])
}
