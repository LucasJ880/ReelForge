# ============================================================
# Aivora 中国大陆部署环境变量示例（.env.china.example）
# ============================================================
#
# 用法：
#   cp .env.china.example .env.production.cn
#   填入真实密钥（**绝对不要提交真实密钥到 git**）
#   docker compose --env-file .env.production.cn up -d
#
# 与 .env.example 的关系：
#   - 海外部署仍然用 .env.example（Vercel / Neon / OpenAI / Vercel Blob）
#   - 国内部署用这份模板 → 走火山方舟 + 火山 TOS + 火山 RDS
#   - 业务代码通过 provider 抽象层根据 AI_PROVIDER / STORAGE_PROVIDER / VIDEO_PROVIDER
#     自动切换。**业务代码不写死 region**。
#
# 任何"FIXME"/"TODO"标记必须在上线前替换为真实值。

# ============================================================
# 1. 区域与部署目标（强制声明，env validation 会检查）
# ============================================================
REGION=cn
DEPLOYMENT_TARGET=china
APP_BASE_URL=https://demo.aivora.cn
NEXT_PUBLIC_APP_URL=https://demo.aivora.cn
NEXTAUTH_URL=https://demo.aivora.cn

# ============================================================
# 2. 数据库（火山 RDS PostgreSQL 或自建 PG）
# ============================================================
# 例：postgresql://aivora:PASSWORD@pgm-xxxx.rds.volces.com:5432/aivora?sslmode=require
# 注意：火山 RDS 默认要求 SSL；本机/容器互通可暂用 sslmode=prefer
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/aivora?sslmode=require

# ============================================================
# 3. Provider 路由（业务代码读这三个变量决定走哪个 provider）
# ============================================================
AI_PROVIDER=volcengine
STORAGE_PROVIDER=volcengine_tos
VIDEO_PROVIDER=volcengine

# 可选：公网回源 / CDN 加速域名（用于生成视频成品的可下载/可分享 URL）
# 留空时使用 VOLCENGINE_TOS_PUBLIC_BASE_URL；
# 配置后所有 getPublicUrl() 会优先返回 CDN URL。
CDN_BASE_URL=

# ============================================================
# 4. 火山引擎账号（IAM 子账号，最小权限：TOS 读写 + Ark 调用）
# ============================================================
VOLCENGINE_ACCESS_KEY_ID=
VOLCENGINE_SECRET_ACCESS_KEY=
# 默认 region；TOS / Ark 都默认 cn-beijing，可按实际机房调整
VOLCENGINE_REGION=cn-beijing

# ============================================================
# 5. 火山方舟 Ark（豆包 LLM + 视觉 + 视频）
# ============================================================
# Ark API Key（推荐用接入点 endpoint key，而非账号 AK/SK）
VOLCENGINE_ARK_API_KEY=
# 默认与 ARK_BASE_URL 一致；二者任意一个填写即可
VOLCENGINE_ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 豆包模型（按实际接入点 ID 替换；推荐用接入点 ID 而非模型名）
# 文本：脚本 / 角度 / 调研 / 蒸馏
VOLCENGINE_ARK_MODEL_TEXT=doubao-pro-32k
# 视觉：参考图分析
VOLCENGINE_ARK_MODEL_VISION=doubao-1.5-vision-pro-32k

# === 视频生成（即梦 / Seedance；与 .env.example 同名，兼容现有代码）===
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_VIDEO_MODEL=doubao-seedance-2-0-260128
ARK_VIDEO_I2V_MODEL=

# 强制视频走 mock（开发期；生产关闭）
VIDEO_ENGINE_MOCK=false
# 强制 LLM 走 mock（开发期；生产关闭）
LLM_FORCE_MOCK=false
# 强制图像走 mock（中国大陆 demo 阶段建议保留 true，等接入豆包文生图后切 false）
IMAGE_ENGINE_MOCK=true

# Seedance 用时阈值（分钟） & 连续错误阈值
SEEDANCE_TIMEOUT_MIN=15
SEEDANCE_POLL_ERROR_THRESHOLD=3
# Webhook 回调（可选；填了走双保险=轮询+回调）
SEEDANCE_CALLBACK_URL=

# ============================================================
# 6. 火山 TOS（对象存储）
# ============================================================
# Endpoint 示例：tos-cn-beijing.volces.com / tos-cn-shanghai.volces.com / tos-cn-guangzhou.volces.com
VOLCENGINE_TOS_ENDPOINT=tos-cn-beijing.volces.com
VOLCENGINE_TOS_REGION=cn-beijing

# 两个 bucket（必须事先在火山控制台创建，建议默认私有）：
#   uploads — 用户上传素材
#   renders — AI 生成的视频成品 / 图片
# 命名约束：3-63 字符，全小写，仅字母/数字/中划线
VOLCENGINE_TOS_BUCKET_UPLOADS=aivora-cn-uploads
VOLCENGINE_TOS_BUCKET_RENDERS=aivora-cn-renders

# Bucket 公网域名（如果走自定义域名 / CDN）；不配置时使用默认 endpoint URL
VOLCENGINE_TOS_PUBLIC_BASE_URL=

# ============================================================
# 7. 鉴权（与海外保持一致）
# ============================================================
# JWT 密钥（生成: openssl rand -hex 32）
AUTH_SECRET=

# 首次部署种子管理员账号（仅首次 prisma db seed 时生效）
SEED_ADMIN_EMAIL=admin@aivora.cn
SEED_ADMIN_PASSWORD=

# Cron 调度密钥（worker 调 /api/cron/* 时验证）
CRON_SECRET=

# ============================================================
# 8. 合规与运营开关
# ============================================================
# China compliance mode：true 时启用所有大陆合规默认值
#   - billing/支付页面禁用
#   - 内容审核拦截器启用（取决于 CONTENT_REVIEW_ENABLED）
#   - footer 显示"AI 生成内容声明 + 备案号"占位
CHINA_COMPLIANCE_MODE=true

# 内容审核（火山内容安全 Content Moderation）：
# Phase 1 默认 false（走 noop provider，记录调用点但不拦截）
# 公开测试 / 上线前必须改 true 并配置 provider
CONTENT_REVIEW_ENABLED=false
CONTENT_REVIEW_PROVIDER=noop
# CONTENT_REVIEW_PROVIDER=volcengine

# 短信登录（Phase 2+，本阶段 false）
SMS_LOGIN_ENABLED=false
SMS_PROVIDER=
SMS_ACCESS_KEY=
SMS_SECRET_KEY=
SMS_SIGN_NAME=

# 支付（Phase 3+，本阶段 false）
PAYMENT_ENABLED=false

# ============================================================
# 9. 视频拼接 runtime（必须）
# ============================================================
# 中国大陆部署强制 local（容器内自带 ffmpeg），不依赖 GitHub Actions
STITCH_RUNTIME=local
ENABLE_VIDEO_STITCHING=true
FFMPEG_BIN=ffmpeg

# ============================================================
# 10. i18n（强制 zh-CN）
# ============================================================
NEXT_PUBLIC_DEFAULT_LOCALE=zh-CN

# ============================================================
# 11. 可选 / 海外服务（中国大陆默认全部留空）
# ============================================================
# OpenAI（如果 AI_PROVIDER=openai，则需配置；否则留空）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Vercel Blob（如果 STORAGE_PROVIDER=vercel_blob，则需配置；否则留空）
BLOB_READ_WRITE_TOKEN=

# Stripe（PAYMENT_ENABLED=false 时无需配置）
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# Apify TikTok 抓取（中国大陆建议留空走 LLM 模式）
APIFY_TOKEN=

# TikTok 海外发布（中国大陆 demo 不用）
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# HeyGen 数字人（默认 mock）
DIGITAL_HUMAN_PROVIDER=mock
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=

# remove.bg 抠图（可选）
REMOVE_BG_API_KEY=
