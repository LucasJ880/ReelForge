generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  DRAFT
  CONTENT_GENERATED
  VIDEO_GENERATING
  VIDEO_FAILED
  VIDEO_READY
  DONE
}

enum VideoJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum BatchStatus {
  PENDING
  RUNNING
  PAUSED
  COMPLETED
  FAILED
}

model Batch {
  id                String      @id @default(cuid())
  name              String
  status            BatchStatus @default(PENDING)
  totalCount        Int         @default(0)
  completedCount    Int         @default(0)
  failedCount       Int         @default(0)
  videoParams       Json?
  concurrency       Int         @default(2)
  autoGenerateVideo Boolean     @default(true)
  errorMessage      String?
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  projects Project[]

  @@index([status])
  @@index([createdAt(sort: Desc)])
}

model ProductCatalog {
  id          String   @id @default(cuid())
  name        String
  productLine String
  color       String
  description String
  features    String[]
  sizes       Json
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  projects Project[]

  @@index([productLine])
  @@index([isActive])
}

model Project {
  id              String        @id @default(cuid())
  keyword         String
  category        String?
  status          ProjectStatus @default(DRAFT)
  errorMessage    String?
  retryCount      Int           @default(0)
  batchId         String?
  batchIndex      Int?
  productId       String?
  imageUrls       String[]
  primaryImageUrl String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  batch       Batch?          @relation(fields: [batchId], references: [id])
  product     ProductCatalog? @relation(fields: [productId], references: [id])
  contentPlan ContentPlan?
  videoJob    VideoJob?

  @@index([status])
  @@index([category])
  @@index([batchId])
  @@index([productId])
  @@index([createdAt(sort: Desc)])
}

model ContentPlan {
  id               String   @id @default(cuid())
  projectId        String   @unique
  script           String
  videoPrompt      String
  videoPromptPart2 String?
  caption          String
  hashtags         String[]
  contentAngles    Json
  modelUsed        String
  tokenUsage       Json?
  createdAt        DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model VideoJob {
  id               String         @id @default(cuid())
  projectId        String         @unique
  provider         String         @default("jimeng")
  channel          String         @default("pro") // "pro" (Seedance) | "free" (Pexels+FFmpeg)
  providerJobId    String?
  providerJobId2   String?
  status           VideoJobStatus @default(PENDING)
  videoUrl         String?
  videoUrl2        String?
  stitchedVideoUrl String?
  thumbnailUrl     String?
  duration         Int            @default(15)
  resolution       String         @default("1080p")
  ratio            String         @default("9:16")
  segment          Int?
  lastFrameUrl     String?
  /// 多变体: [{ jobId, videoUrl, thumbnailUrl, status, selected? }]
  variants         Json?
  selectedVariant  Int            @default(0)
  /// Free 通道的素材 manifest: { scenes, audio, subtitles, bgm }
  manifest         Json?
  errorMessage     String?
  retryCount       Int            @default(0)
  createdAt        DateTime       @default(now())
  completedAt      DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

enum UserRole {
  ADMIN
  USER
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  hashedPassword String
  name           String?
  role           UserRole @default(USER)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
