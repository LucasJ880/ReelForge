generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================================================
// 1. 身份（仅内部 Admin）
// =========================================================

enum AdminRole {
  SUPER_ADMIN
  OPERATOR
  REVIEWER
}

model AdminUser {
  id             String    @id @default(cuid())
  email          String    @unique
  hashedPassword String
  name           String?
  role           AdminRole @default(OPERATOR)
  /// Phase 5（Unified Input）：persona discriminator
  /// 取值："BUSINESS" | "PERSONAL" | "OPERATOR" | "SUPER_ADMIN"
  /// 未填写时 src/app/page.tsx 强制跳转 /persona 选择。
  /// 不做成 enum：存量账号默认 "OPERATOR" 走 internal shell。
  userType       String?   @default("OPERATOR")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  createdOrders  DeliveryOrder[]
  qaReviews      QAReview[]
  publishRecords PublishRecord[]
}

// =========================================================
// 1.1 Creative Evidence Card（创意证据卡 · 案例库一等公民）
// =========================================================
//
// 设计原则：
// - 不下载/不自托管第三方视频，referenceUrl 仅记录原平台链接 + thumbnailUrl 仅
//   记录原平台缩略图（来自公开嵌入接口或运营手动收集的合规缩略图）。
// - publicMetricsJson 存的是「在哪个时间点观察到的公开指标」，不承诺实时。
// - structureBreakdown / hookPattern / clientPreviewSummary 是 Aivora 的「原创解读」，
//   不复制原视频字幕、原配音、原镜头脚本。
// - status 用于发布门禁：草稿 → 已审核 → 已发布 → 已归档。

enum CreativeEvidenceStatus {
  DRAFT
  REVIEWED
  PUBLISHED
  ARCHIVED
}

model CreativeEvidenceCard {
  id   String @id @default(cuid())
  /// 稳定 slug，便于 seed 重复执行（upsert by slug）
  slug String @unique

  title     String
  /// 行业枚举字符串：real_estate / pet_business / local_service / restaurant / general
  industry  String
  /// 平台：tiktok / instagram_reels / youtube_shorts / facebook / mixed
  platform  String
  /// 业务目标：get_leads / promote_listing / increase_bookings / announce_offer / brand_awareness
  objective String

  /// 来源平台名（人类可读，如 TikTok / Instagram / YouTube Shorts）
  sourcePlatform String?
  /// 原平台公开链接（不下载、不自托管）
  referenceUrl   String?
  /// 缩略图 URL（来自原平台公开 oEmbed 或运营录入的合规图）
  thumbnailUrl   String?

  /// 公开指标快照：{ observedAt, views, likes, comments, shares, saves, isPaidAd, paidAdNote }
  publicMetricsJson Json?

  /// hook 模式：{ pattern, openingSeconds, hookType: "POV|Curiosity|Stat|Reveal|Pain|Demo", whyItStops }
  hookPattern            Json?
  /// 结构拆解：{ segments:[{ from, to, role, narrative }], pacingNotes }
  structureBreakdownJson Json?

  whyItWorks       String?
  visualStyle      String?
  suggestedUseCase String?
  /// 风险/合规备注：版权、行业合规（地产/金融/医疗）、未授权数字人/克隆声音禁用等
  riskNotes        String?

  /// 0-100 系统推荐分（按行业/目标加权）
  recommendationScore  Int?
  /// 客户预览友好摘要（中文，2-3 句话能让商家秒懂这个卡为啥适合自己）
  clientPreviewSummary String?

  status CreativeEvidenceStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  selectedByOrders DeliveryOrder[] @relation("DeliveryOrderSelectedCard")

  @@index([industry])
  @@index([platform])
  @@index([objective])
  @@index([status])
  @@index([recommendationScore(sort: Desc)])
}

// =========================================================
// 1.2 GTM Demo Leads
// =========================================================

enum RealFootageDemoLeadStatus {
  NEW
  CONTACTED
  DEMO_BOOKED
  NOT_FIT
  TEST
}

model RealFootageDemoLead {
  id            String                    @id @default(cuid())
  name          String
  email         String
  businessType  String
  monthlyVolume String
  painPoint     String
  source        String                    @default("demo/real-footage-ads")
  status        RealFootageDemoLeadStatus @default(NEW)
  hiddenAt      DateTime?
  createdAt     DateTime                  @default(now())

  @@index([email])
  @@index([status])
  @@index([hiddenAt])
  @@index([createdAt(sort: Desc)])
}

// =========================================================
// 2. 交付单 DeliveryOrder（替代旧 Project）
// =========================================================

enum DeliveryOrderStatus {
  DRAFT
  RESEARCHING
  SELLING_POINTS_READY
  ROUND_ACTIVE
  AWAITING_DISTILLATION
  NEXT_ROUND_SCHEDULED
  COMPLETED
  CANCELLED
}

model DeliveryOrder {
  id     String              @id @default(cuid())
  title  String
  status DeliveryOrderStatus @default(DRAFT)

  /// 第一阶段仅 "blanket"；后续可扩展
  productCategory String @default("blanket")
  /// 第一阶段仅 "tiktok"
  targetPlatform  String @default("tiktok")

  /// 目标国家，例：US, CA_QC, DE
  targetCountry       String
  /// 目标语言，例：en, fr, de
  targetLanguage      String
  /// 区域变体（可选），例：en-US, fr-CA
  targetRegionVariant String?

  /// 产品结构化输入：sku、材质、尺寸、价格、卖点提示、URL、图片、竞品链接等
  productInput Json

  /// Client Project Wizard 输入（北美本地商家版）：
  /// {
  ///   businessName, industry, objective, targetPlatforms, videoLengthSec,
  ///   brandTone, brandAssets:{ logoUrl, primaryColor, accentColor, websiteUrl, phone, ctaText }
  /// }
  /// 与 productInput 解耦，便于商家友好向导单独维护，不影响现有 admin 流程。
  clientBrief Json?

  /// Wizard 阶段选中的创意证据卡 id；多卡选择请放 clientBrief.candidateCardIds
  selectedCreativeCardId String?
  selectedCreativeCard   CreativeEvidenceCard? @relation("DeliveryOrderSelectedCard", fields: [selectedCreativeCardId], references: [id])

  /// 终止策略：默认 3 轮 + 支持 Admin 手动提前结算
  maxRounds    Int     @default(3)
  errorMessage String?

  createdById String?
  createdBy   AdminUser? @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  marketResearch   MarketResearch?
  sellingPoints    SellingPoint[]
  rounds           Round[]
  distillations    DistillationFeature[]
  rawAssets        RawAsset[]
  aiUsageLogs      AIUsageLog[]
  wizardRenderJobs WizardRenderJob[]     @relation("DeliveryOrderWizardRenders")
  logoGenerations  LogoGeneration[]

  @@index([status])
  @@index([productCategory])
  @@index([selectedCreativeCardId])
  @@index([createdAt(sort: Desc)])
}

// =========================================================
// 2.1 真实素材库 RawAsset / FootageShot
// =========================================================

enum RawAssetType {
  VIDEO
  IMAGE
  AUDIO
}

enum RawAssetStatus {
  UPLOADED
  PROCESSING
  INDEXED
  FAILED
}

enum FootageShotStatus {
  CANDIDATE
  SELECTED
  REJECTED
}

/// Asset QA 业务判断（规则引擎/AI 都会写入）：
/// - PENDING: 已上传但未跑 QA
/// - USABLE: 直接可用
/// - BARELY_USABLE: 需要剪/调色/降噪后可用
/// - RETAKE_RECOMMENDED: 建议重拍（理由写入 qaResult.reasons[]）
/// - MISSING_SHOT: 客户没有提供该镜头（仅在批量 missing-shot 检测时挂在虚拟 RawAsset 上，MVP 不创建虚拟行）
enum AssetQAStatus {
  PENDING
  USABLE
  BARELY_USABLE
  RETAKE_RECOMMENDED
  MISSING_SHOT
}

model RawAsset {
  id              String        @id @default(cuid())
  deliveryOrderId String
  deliveryOrder   DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)

  type          RawAssetType
  status        RawAssetStatus @default(UPLOADED)
  name          String
  url           String
  mimeType      String?
  durationMs    Int?
  width         Int?
  height        Int?
  fileSizeBytes Int?
  checksum      String?

  notes        String?
  tags         Json?
  metadata     Json?
  errorMessage String?

  /// 业务级 QA 判断（与 RawAssetStatus 区分：status 是处理流水线状态，qaStatus 是「能不能进剪辑」业务结论）
  qaStatus       AssetQAStatus @default(PENDING)
  /// QA 结果详情：{ checks:[{rule,passed,severity,message}], reasons:[], retakeSuggestions:[], orientation, aspectRatio, score }
  qaResult       Json?
  /// 客户标注的镜头用途：hook / proof / demo / lifestyle / cta / b_roll
  assetRole      String?
  /// Phase 5（Unified Input）：asset-classifier 推断角色
  /// 取值："product_image" | "reference_image" | "logo" | "intro_clip" | "outro_clip"
  ///       | "ad_clip" | "store_clip" | "product_demo_clip" | "logo_animation" | "existing_commercial"
  /// 未填写表示尚未跑过分类；与 assetRole 分开（assetRole 是客户手动标记）。
  inferredRole   String?
  /// inferredRole 置信度（0..1）；低置信度 UI 应展示「请确认」
  roleConfidence Float?
  /// 关联到具体的 ScenePlan.id（外键，cuid）。
  /// 注意：这里是真实 FK，不是 storyboard JSON 内部的 "shot-1" 字符串；
  /// 如果想引用 storyboard 内部 shot 索引，请用 metadata.storyboardShotIndex 字段。
  /// onDelete: SetNull —— 当 ScenePlan 因为重新生成 storyboard 被删除时，
  /// 这里自动置空，由 detectMissingShotsForBrief 再次报缺。
  matchedShotId  String?
  matchedShot    ScenePlan?    @relation("AssetMatchedShot", fields: [matchedShotId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shots FootageShot[]

  @@index([deliveryOrderId])
  @@index([status])
  @@index([qaStatus])
  @@index([type])
  @@index([matchedShotId])
}

model FootageShot {
  id         String   @id @default(cuid())
  rawAssetId String
  rawAsset   RawAsset @relation(fields: [rawAssetId], references: [id], onDelete: Cascade)

  status         FootageShotStatus @default(CANDIDATE)
  shotIndex      Int
  startMs        Int
  endMs          Int
  durationMs     Int
  thumbnailUrl   String?
  transcript     String?
  visualSummary  String?
  tags           String[]          @default([])
  qualityScore   Float?
  usabilityNotes String?
  technical      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([rawAssetId, shotIndex])
  @@index([rawAssetId])
  @@index([status])
}

// =========================================================
// 3. 市场分析 / 卖点
// =========================================================

enum ResearchStatus {
  PENDING
  RUNNING
  READY
  FAILED
}

model MarketResearch {
  id              String        @id @default(cuid())
  deliveryOrderId String        @unique
  deliveryOrder   DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)

  status       ResearchStatus @default(PENDING)
  /// LLM 生成的结构化调研：trend, keywords, competitors, hot_hooks, audience_notes, timing
  structured   Json?
  /// LLM 自然语言摘要
  summary      String?
  /// Token 用量等调试信息
  debug        Json?
  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SellingPoint {
  id              String        @id @default(cuid())
  deliveryOrderId String
  deliveryOrder   DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)

  /// 分类：core / scene / emotional / localization
  kind          String
  rank          Int
  title         String
  body          String
  /// 来源证据（研究片段、产品事实）
  evidence      Json?
  /// 本地化表达变体：{ "en-US": "...", "fr-CA": "..." }
  localizations Json?

  createdAt DateTime @default(now())

  @@index([deliveryOrderId])
}

// =========================================================
// 4. 赛马 Round + ContentAngle
// =========================================================

enum RoundStatus {
  PLANNED
  ANGLES_READY
  VIDEOS_IN_FLIGHT
  AWAITING_PUBLISH
  LIVE
  METRICS_WINDOWS_PENDING
  SCORING
  RANKED
  DISTILLATION_PENDING
  CLOSED
}

model Round {
  id              String        @id @default(cuid())
  deliveryOrderId String
  deliveryOrder   DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)

  roundIndex Int
  status     RoundStatus @default(PLANNED)

  /// 该轮绑定的主卖点 id（可选，冗余字段便于展示）
  primarySellingPointId String?
  /// 赛马槽位：默认 3 优化 + 2 探索 = 5 条
  optimizationSlots     Int     @default(3)
  explorationSlots      Int     @default(2)

  /// 首轮没有上一轮可蒸馏，所以可空；非首轮须指向上一轮
  baseDistillationId String?
  baseDistillation   DistillationFeature? @relation("RoundBaseDistillation", fields: [baseDistillationId], references: [id])

  startedAt DateTime?
  closedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  angles       ContentAngle[]
  scoreReports ScoreReport[]

  @@unique([deliveryOrderId, roundIndex])
  @@index([status])
}

enum AngleType {
  OPTIMIZATION
  EXPLORATION
}

model ContentAngle {
  id      String @id @default(cuid())
  roundId String
  round   Round  @relation(fields: [roundId], references: [id], onDelete: Cascade)

  sortOrder            Int
  type                 AngleType
  title                String
  /// 钩子/视频叙事概念
  hook                 String?
  narrative            String?
  /// 探索型 angle 所采用的主题池 key（如 "asmr"、"pet_steal"、"room_makeover"）
  explorationTheme     String?
  /// 优化型引用的上一轮蒸馏特征 id
  sourceDistillationId String?
  sourceDistillation   DistillationFeature? @relation("AngleSourceDistillation", fields: [sourceDistillationId], references: [id])

  /// 本地化备注（语言、文化、on-camera 形式建议）
  localeNotes Json?

  createdAt DateTime @default(now())

  videoBrief VideoBrief?

  @@index([roundId])
}

// =========================================================
// 5. VideoBrief / Script / ScenePlan / VideoPrompt / VideoJob
// =========================================================

enum VideoBriefStatus {
  BRIEF_PENDING
  SCRIPT_DRAFTING
  SCRIPT_READY
  SCENE_PROMPT_READY
  RENDER_QUEUED
  RENDERING
  RENDER_SUCCEEDED
  RENDER_FAILED
  QA_PENDING
  QA_APPROVED
  QA_REJECTED
  PUBLISH_PENDING
  PUBLISHED
  METRICS_COLLECTING
  SCORED
  ARCHIVED
  DROPPED
}

enum OnCameraMode {
  NONE
  SELF_RAW
  SELF_VOICE_REPLACED
  SELF_SUBTITLED
  UGC_AVATAR
  PRODUCT_ONLY
}

model VideoBrief {
  id             String       @id @default(cuid())
  contentAngleId String       @unique
  contentAngle   ContentAngle @relation(fields: [contentAngleId], references: [id], onDelete: Cascade)

  status VideoBriefStatus @default(BRIEF_PENDING)

  durationSec  Int          @default(20)
  aspectRatio  String       @default("9:16")
  tone         String?
  onCameraMode OnCameraMode @default(PRODUCT_ONLY)

  /// 用户选择的目标成片时长（15/30/60）。
  /// MVP 阶段允许其他值（如 20）以兼容历史数据；分段计划由 segment-planner 兜底。
  targetDurationSec Int   @default(30)
  /// AI Video Director 输出的完整 DirectorPlan JSON（zod schema: src/lib/schemas/director-plan.ts）
  directorPlan      Json?

  /// Phase 5（Unified Input）：persona discriminator，便于后续按 Business / Personal 做 analytics
  /// 取值："BUSINESS" | "PERSONAL"，null 表示未知（历史 brief）
  persona             String?
  /// Phase 5：完整的 VideoGenerationPlan 快照（unified input 生成时落库；DirectorPlan 是子集）
  /// zod schema: src/lib/schemas/unified-input.ts:videoGenerationPlanSchema
  videoGenerationPlan Json?

  /// I2V 参考图（Vercel Blob URL）；支持 1-5 张
  referenceImageUrls String[] @default([])
  /// 最终送审/发布的成片 URL（兼容旧 Sunny Shutter：单段 brief 这里就是 finalVideo URL）
  finalVideoUrl      String?
  /// 最终封面
  finalThumbnailUrl  String?

  /// 多段拼接成片的关联（只在 30s/60s 多段流程下创建）
  finalVideoId String?     @unique
  finalVideo   FinalVideo? @relation(fields: [finalVideoId], references: [id], onDelete: SetNull)

  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  scripts        Script[]
  videoJobs      VideoJob[]
  adEditPlans    AdEditPlan[]
  qaReviews      QAReview[]
  publishRecords PublishRecord[]

  @@index([status])
  @@index([finalVideoId])
}

enum AdEditPlanStatus {
  DRAFT
  READY
  RENDERING
  RENDERED
  REVIEWED
  FAILED
}

model AdEditPlan {
  id           String     @id @default(cuid())
  videoBriefId String
  videoBrief   VideoBrief @relation(fields: [videoBriefId], references: [id], onDelete: Cascade)

  version     Int              @default(1)
  status      AdEditPlanStatus @default(DRAFT)
  title       String
  objective   String?
  durationMs  Int
  aspectRatio String           @default("9:16")

  /// JSON 时间线：clips / overlays / captions / music / render hints
  timeline           Json
  /// JSON Reviewer 打分：hook / pacing / visual_match / offer_clarity / technical_quality
  reviewScores       Json?
  reviewSummary      String?
  reviewerFeedback   Json?
  outputVideoUrl     String?
  outputThumbnailUrl String?
  errorMessage       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([videoBriefId])
  @@index([status])
}

model Script {
  id           String     @id @default(cuid())
  videoBriefId String
  videoBrief   VideoBrief @relation(fields: [videoBriefId], references: [id], onDelete: Cascade)

  version   Int     @default(1)
  language  String
  fullText  String
  hook      String?
  cta       String?
  isCurrent Boolean @default(true)
  /// Wizard 流程下保存完整 ScriptOutput（包含 voiceover/captions/complianceNotes/...）。
  /// Admin 流程不依赖该字段，旧 Script 行此字段为 NULL，service 层会兜底。
  metadata  Json?

  createdAt DateTime @default(now())

  scenePlans ScenePlan[]

  @@index([videoBriefId, isCurrent])
}

model ScenePlan {
  id       String @id @default(cuid())
  scriptId String
  script   Script @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  sceneIndex   Int
  durationSec  Int
  visualIntent String
  onCameraNote String?

  /// 客户拍摄指导（商家版 storyboard 字段）：
  /// {
  ///   shotType, composition, cameraMovement, requiredProps:[],
  ///   commonMistakes:[], lightingNote, audioNote, captionText, voiceoverSegment,
  ///   uploadHints:[]
  /// }
  /// 设计为可空 + JSON，便于现有 ScenePlan 数据完全向后兼容。
  shootingGuide Json?
  /// 是否为必拍镜头（false=可选/B-roll）
  requiredFlag  Boolean @default(true)
  /// 是否需要真人出镜（与 onCameraNote 互补：onCameraNote 是给 director；humanRequired 是给 wizard UI）
  humanRequired Boolean @default(false)

  videoPrompts  VideoPrompt[]
  matchedAssets RawAsset[]    @relation("AssetMatchedShot")

  @@index([scriptId])
}

enum VideoProvider {
  SEEDANCE_T2V
  SEEDANCE_I2V
  FFMPEG_EDIT
}

model VideoPrompt {
  id          String    @id @default(cuid())
  scenePlanId String
  scenePlan   ScenePlan @relation(fields: [scenePlanId], references: [id], onDelete: Cascade)

  provider          VideoProvider
  promptText        String
  negativePrompt    String?
  params            Json?
  /// I2V 时指向已处理好的参考图 URL
  referenceImageUrl String?

  createdAt DateTime @default(now())

  @@index([scenePlanId])
}

enum VideoJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

model VideoJob {
  id           String     @id @default(cuid())
  videoBriefId String
  videoBrief   VideoBrief @relation(fields: [videoBriefId], references: [id], onDelete: Cascade)

  provider      VideoProvider
  externalJobId String?
  status        VideoJobStatus @default(QUEUED)

  outputVideoUrl String?
  outputThumbUrl String?
  /// 内部/管理员错误（包含原始 Provider 错误，仅 debug 区可见）
  errorMessage   String?
  /// 用户安全的错误描述（已脱敏的中文友好提示，可直接展示给客户）
  userSafeError  String?
  retryCount     Int     @default(0)

  /// 我们调用 Provider 提交时间
  submittedAt        DateTime?
  /// Provider 第一次确认 RUNNING/processing 的时间（可空）
  startedAt          DateTime?
  /// 终态时间
  finishedAt         DateTime?
  /// 上次成功调用 Provider 状态接口的时间
  lastCheckedAt      DateTime?
  /// Provider 原始 status（如 "queued" / "running" / "succeeded" / "failed" / "expired"）
  lastProviderStatus String?
  /// 视频生成超过该时间仍未终态时，UI 显示「用时较长」
  timeoutAt          DateTime?
  /// 累计轮询次数（用于「3 连错败下线」逻辑）
  pollErrors         Int       @default(0)

  /// 段索引（NULL = 旧的单段 / 兼容 Sunny Shutter；多段流程中从 0 开始）
  segmentIndex       Int?
  /// 该段实际请求的时长（一般 15s）
  segmentDurationSec Int?
  /// 多段流程下指向同一 FinalVideo 的所有段
  finalVideoId       String?
  finalVideo         FinalVideo? @relation(fields: [finalVideoId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([externalJobId])
  @@index([videoBriefId])
  @@index([finalVideoId, segmentIndex])
}

// =========================================================
// 5.1 FinalVideo（多段拼接结果）
// =========================================================
//
// 设计原则（Sunny Shutter 兼容铁律）：
// - 旧 brief（segmentIndex IS NULL 的 VideoJob）不创建 FinalVideo 记录，
//   syncBriefStatus 会沿用「首段 SUCCEEDED 就把 outputVideoUrl 写到 VideoBrief.finalVideoUrl」的旧逻辑。
// - 新流程（30s/60s）会先创建 FinalVideo (status=PENDING)，再为每段创建 VideoJob 指向它。
// - 当所有段 SUCCEEDED → status=STITCHING → ffmpeg → status=READY/FAILED。

enum FinalVideoStatus {
  PENDING
  STITCHING
  READY
  FAILED
}

model FinalVideo {
  id String @id @default(cuid())

  targetDurationSec Int
  segmentCount      Int

  status           FinalVideoStatus @default(PENDING)
  stitchedVideoUrl String?
  thumbnailUrl     String?
  ffmpegError      String?
  /// 累计 ffmpeg 失败次数（>= 3 时停止自动重试）
  stitchAttempts   Int              @default(0)

  startedAt  DateTime?
  finishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brief    VideoBrief?
  segments VideoJob[]

  @@index([status])
}

// =========================================================
// 5.2 LogoGeneration（AI 生成 Logo 候选）
// =========================================================

model LogoGeneration {
  id              String        @id @default(cuid())
  deliveryOrderId String
  deliveryOrder   DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)

  prompt    String
  /// 用户选择的风格标签：modern / minimal / luxury / playful / tech / natural / local
  styleHint String?
  /// 实际使用的 image 模型（默认 gpt-image-1，mock 模式为 "mock"）
  model     String

  /// 候选图 URL 数组（已上传到 Vercel Blob）
  generatedUrls String[] @default([])
  /// 用户最终选中的 URL（同时会写回 DeliveryOrder.clientBrief.brandAssets.logoUrl）
  selectedUrl   String?

  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deliveryOrderId])
  @@index([createdAt(sort: Desc)])
}

// =========================================================
// 6. QA Review
// =========================================================

enum QAStatus {
  PENDING
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

model QAReview {
  id           String     @id @default(cuid())
  videoBriefId String
  videoBrief   VideoBrief @relation(fields: [videoBriefId], references: [id], onDelete: Cascade)

  /// AI QA 产出（独立于人工审核，先跑一次供审核员参考）
  aiOverallScore   Float?
  /// JSON：hook_quality / topic_alignment / angle_alignment / format_alignment / cta_quality / duration_fitness / brief_alignment / technical_completeness
  aiScoreBreakdown Json?
  aiIssues         Json?
  aiSuggestions    Json?
  /// AI 建议的路由：auto_pass / needs_review / reject
  aiReviewRoute    String?

  /// 人工最终结论
  status          QAStatus   @default(PENDING)
  reviewerId      String?
  reviewer        AdminUser? @relation(fields: [reviewerId], references: [id])
  reviewerComment String?
  reviewedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// =========================================================
// 7. Publish + Metrics
// =========================================================

enum PublishStatus {
  PENDING
  DOWNLOADED
  UPLOADED
  PUBLISHED
  FAILED
  CANCELLED
}

model PublishRecord {
  id           String     @id @default(cuid())
  videoBriefId String
  videoBrief   VideoBrief @relation(fields: [videoBriefId], references: [id], onDelete: Cascade)

  platform       String  @default("tiktok")
  /// TikTok 侧的贴文/视频 id；运营人工上传成功后回填
  externalPostId String?
  publishUrl     String?

  status        PublishStatus @default(PENDING)
  publishedAt   DateTime?
  publishedById String?
  publishedBy   AdminUser?    @relation(fields: [publishedById], references: [id])

  /// 运营上传时的备注
  operatorNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  metricsSnapshots MetricsSnapshot[]

  @@index([status])
  @@index([externalPostId])
}

model MetricsSnapshot {
  id              String        @id @default(cuid())
  publishRecordId String
  publishRecord   PublishRecord @relation(fields: [publishRecordId], references: [id], onDelete: Cascade)

  /// 12 | 24 | 48
  windowHours Int
  capturedAt  DateTime
  /// 数据来源：csv_manual / api（V2）
  source      String   @default("csv_manual")

  /// 内容指标：views, completion_rate, retention_3s, shares, saves, likes, comments
  metrics Json

  createdAt DateTime @default(now())

  @@unique([publishRecordId, windowHours])
  @@index([capturedAt])
}

// =========================================================
// 8. Scoring + Distillation
// =========================================================

model ScoreReport {
  id      String @id @default(cuid())
  roundId String
  round   Round  @relation(fields: [roundId], references: [id], onDelete: Cascade)

  /// 当为 null 时表示轮次级汇总；否则对应某条 VideoBrief
  videoBriefId String?

  contentScore   Float?
  /// MVP 阶段不计算，预留 V2
  commerceScore  Float?
  compositeScore Float?
  /// 记录当时权重，方便复盘
  weights        Json?
  /// AI 解释：为什么得了这个分；并给出蒸馏建议的自然语言
  explanation    String?

  /// 若为轮次级 rank 榜：[{videoBriefId, rank, score}]
  ranking Json?

  createdAt DateTime @default(now())

  @@index([roundId])
  @@index([videoBriefId])
}

model DistillationFeature {
  id              String        @id @default(cuid())
  deliveryOrderId String
  deliveryOrder   DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)

  sourceRoundId String?
  /// 自然语言总结（供 Admin 阅读）
  summary       String
  /// 结构化特征：{ hook_type, title_structure, selling_point_order, cta_position, format, duration, scene_rhythm }
  structured    Json

  createdAt DateTime @default(now())

  basedRounds Round[]        @relation("RoundBaseDistillation")
  angles      ContentAngle[] @relation("AngleSourceDistillation")

  @@index([deliveryOrderId])
}

// =========================================================
// 9. AI Usage Log（每次 AI 调用都要可追踪）
// =========================================================

enum AIUsageStatus {
  SUCCESS
  FAILED
  MOCK
}

model AIUsageLog {
  id String @id @default(cuid())

  /// 业务功能 key，例：creative_evidence_breakdown / client_script /
  /// storyboard / shooting_guide / asset_qa / director / reviewer / qa
  feature  String
  provider String  @default("openai")
  model    String?

  /// 关联到具体 DeliveryOrder（可选；后台 seed/breakdown 调用可为空）
  deliveryOrderId String?
  deliveryOrder   DeliveryOrder? @relation(fields: [deliveryOrderId], references: [id], onDelete: SetNull)
  /// 关联到 CreativeEvidenceCard（可选，用于 breakdown 流程）
  creativeCardId  String?

  /// 用户/Admin id（可选，未登录脚本/cron 可空）
  actorUserId String?

  /// LLM 调用上下文摘要（裁剪后），不写入完整 prompt 以免泄露 PII
  inputSummary  String?
  /// 模型输出摘要（裁剪后）；完整结果由对应业务表保存
  outputSummary String?

  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  /// 估算成本（USD）；当 provider 不暴露价格时由 service 层按 model 估算
  costEstimateUsd  Float?

  /// prompt 模板版本号（与 src/lib/prompts/* 中的 PROMPT_VERSION 对应）
  promptVersion String?

  status       AIUsageStatus @default(SUCCESS)
  errorMessage String?
  durationMs   Int?

  createdAt DateTime @default(now())

  @@index([feature])
  @@index([provider])
  @@index([deliveryOrderId])
  @@index([creativeCardId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
}

// =========================================================
// 10. Wizard Render Job（客户向导版渲染任务）
// =========================================================
//
// 与现有 VideoJob（admin pipeline 用）刻意保持隔离：
// - VideoJob   依赖 VideoBrief / ContentAngle / AdEditPlan，是赛马流程产物；
// - WizardRenderJob 直接挂在 DeliveryOrder 上，输入是客户上传的 RawAsset + 客户自己挑的脚本/分镜，
//   输出可以是 REAL / DRAFT / MOCK 三种模式之一。
// 这样 wizard MVP 不会因为 admin pipeline 的复杂度被卡住，
// 也不会污染 admin 的 VideoJob 状态机。

enum WizardRenderJobStatus {
  QUEUED
  RUNNING
  /// 真 FFmpeg 渲染成功，outputVideoUrl 是真实 MP4
  SUCCEEDED
  /// 半成品：不是完整成片，但 UI 可以预览（首个素材 + manifest）
  DRAFT_READY
  /// 完全占位：连素材都没准备好，只能给 UI 一个 placeholder
  MOCK
  FAILED
}

enum WizardRenderJobMode {
  /// 真 FFmpeg 渲染（要求 ENABLE_WIZARD_FFMPEG_RENDER=true 且素材就绪）
  REAL
  /// 草稿渲染（首个素材 + manifest fallback；UI 应明示 "Draft Preview"）
  DRAFT
  /// 模拟渲染（完全 placeholder；UI 应明示 "Mock Preview"）
  MOCK
}

model WizardRenderJob {
  id String @id @default(cuid())

  deliveryOrderId String
  deliveryOrder   DeliveryOrder @relation("DeliveryOrderWizardRenders", fields: [deliveryOrderId], references: [id], onDelete: Cascade)

  status WizardRenderJobStatus @default(QUEUED)
  mode   WizardRenderJobMode   @default(DRAFT)

  aspectRatio String @default("9:16")
  durationSec Int    @default(30)

  /// 输入快照：根据 ScenePlan/Script/RawAsset 派生出的 timeline，便于复盘
  /// { clips:[{ sceneIndex, sourceUrl, startMs, endMs, captionText }], cta, brand: { logoUrl, primaryColor }, ... }
  timeline      Json
  /// 触发渲染时的 ClientBrief 快照（zod-parsed）
  briefSnapshot Json?

  /// 输出
  outputVideoUrl     String?
  outputThumbnailUrl String?
  /// 当走 DRAFT/MOCK fallback 时，把 manifest 存到 Blob 或 data: URL
  manifestUrl        String?

  /// 解释为什么走了 DRAFT/MOCK，UI 直接展示给客户看
  fallbackReason String?
  errorMessage   String?

  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([deliveryOrderId])
  @@index([status])
  @@index([mode])
  @@index([createdAt(sort: Desc)])
}
