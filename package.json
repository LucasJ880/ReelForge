{
  "name": "aivora",
  "version": "0.2.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "predev": "prisma generate && tsx scripts/check-real-mode.ts || true",
    "dev": "next dev",
    "dev:mock": "LLM_FORCE_MOCK=true VIDEO_ENGINE_MOCK=true IMAGE_ENGINE_MOCK=true VIDEO_ENGINE_MOCK_LATENCY_MS=0 npm run dev",
    "walkthrough:mock": "tsx --env-file=.env.local scripts/mock-walkthrough-harness.ts",
    "sunny:merchant-journey": "tsx --env-file=.env.local scripts/sunny-shutter-merchant-journey.ts",
    "backfill:business-titles": "tsx --env-file=.env.local scripts/backfill-business-order-titles.ts",
    "acceptance:mock": "npm run typecheck && npm run e2e:phase4:mock && node --import tsx --test tests/i18n-coverage.test.ts tests/shell-i18n-wiring.test.ts tests/business-locale-regression.test.ts tests/business-display-title.test.ts tests/business-order-title-service.test.ts && npm run walkthrough:mock",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:visual": "playwright test tests/e2e/editorial.visual.spec.ts",
    "test:visual:update": "playwright test tests/e2e/editorial.visual.spec.ts --update-snapshots",
    "test:a11y": "playwright test tests/e2e/editorial.a11y.spec.ts",
    "test:golden-path": "npm run build && npm run test:golden-path:run",
    "test:golden-path:run": "dotenv -e .env.local -- playwright test --config=playwright.golden-path.config.ts",
    "test:phase34:routes": "npm run build && dotenv -e .env.local -- playwright test --config=playwright.phase34.config.ts",
    "test:final-acceptance": "dotenv -e .env.local -- playwright test --config=playwright.final-acceptance.config.ts",
    "test:final-acceptance:soak": "FINAL_ACCEPTANCE_SOAK_MS=300000 FINAL_ACCEPTANCE_MONITOR_DELAY_MS=30000 dotenv -e .env.local -- playwright test --config=playwright.final-acceptance.config.ts",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e .env.local -- prisma migrate deploy",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "postinstall": "prisma generate",
    "db:seed": "dotenv -e .env.local -- tsx prisma/seed.ts",
    "db:seed:creative-cards": "dotenv -e .env.local -- tsx scripts/seed-creative-evidence-cards.ts",
    "demo:generate:walkthrough": "tsx scripts/generate-real-footage-walkthrough-video.ts",
    "demo:check:walkthrough": "tsx scripts/check-real-footage-walkthrough-video.ts",
    "demo:stitch:walkthrough": "tsx scripts/stitch-real-footage-walkthrough-video.ts",
    "demo:gen:petkit": "tsx scripts/generate-pet-kit-walkthrough-video.ts",
    "demo:check:petkit": "tsx scripts/check-pet-kit-walkthrough-video.ts",
    "demo:vo:petkit": "tsx scripts/generate-pet-kit-voiceover.ts",
    "demo:stitch:petkit": "tsx scripts/stitch-pet-kit-walkthrough-video.ts",
    "demo:gen:evidence": "tsx scripts/generate-pet-evidence-clips.ts",
    "codemap:build": "tsx scripts/build-codemap.ts",
    "context:find": "tsx scripts/context-router.ts",
    "context:video": "tsx scripts/context-router.ts video generation ffmpeg demo blob",
    "tokens:generate": "tsx scripts/generate-design-tokens.ts",
    "demo:mock-business-flow": "tsx scripts/demo-mock-business-flow.ts",
    "demo:brand-overlay": "tsx scripts/demo-brand-overlay.ts",
    "demo:curtain": "tsx scripts/generate-curtain-viral-ads.ts",
    "demo:curtain:publish": "tsx scripts/publish-curtain-videos-to-library.ts",
    "demo:curtain:v2": "tsx scripts/regenerate-curtain-videos-v2.ts",
    "demo:curtain:replace": "tsx scripts/replace-curtain-videos-in-library.ts",
    "acceptance:real:backend": "tsx --env-file=.env.local scripts/real-video-acceptance-backend.ts",
    "acceptance:sunnyshutter:batch10": "tsx --env-file=.env.local scripts/real-video-acceptance-sunnyshutter-batch10.ts",
    "acceptance:sunnyshutter:batch10:submit": "ACCEPTANCE_SUBMIT=1 SUNNYSHUTTER_VIDEO_FAST=1 tsx --env-file=.env.local scripts/real-video-acceptance-sunnyshutter-batch10.ts",
    "acceptance:sunnyshutter:shade:batch10": "tsx --env-file=.env.local scripts/real-video-acceptance-sunnyshutter-shade-batch10.ts",
    "acceptance:sunnyshutter:shade:batch10:submit": "ACCEPTANCE_SUBMIT=1 SUNNYSHUTTER_VIDEO_FAST=1 tsx --env-file=.env.local scripts/real-video-acceptance-sunnyshutter-shade-batch10.ts",
    "brand:sunnyshutter:end-card": "tsx --env-file=.env.local scripts/generate-sunnyshutter-end-card.ts",
    "brand:sunnyshutter:business-card": "tsx --env-file=.env.local scripts/generate-sunnyshutter-business-card-endcard.ts",
    "frame:qa": "tsx scripts/frame-qa.ts",
    "demo:rehearsal": "tsx scripts/demo-rehearsal-e2e.ts",
    "demo:sunny-investor": "tsx scripts/sunny-shutter-investor-demo.ts",
    "demo:sunny-investor:v21": "tsx scripts/sunny-shutter-investor-demo-v21.ts",
    "demo:sunny-investor:v21:submit": "tsx scripts/sunny-shutter-investor-demo-v21.ts --phase=submit",
    "demo:sunny-investor:v21:wait": "tsx scripts/sunny-shutter-investor-demo-v21.ts --phase=wait",
    "demo:sunny-investor:v21:assemble": "tsx scripts/sunny-shutter-investor-demo-v21.ts --phase=assemble",
    "demo:sunny-investor:v21:publish": "tsx scripts/sunny-shutter-investor-demo-v21.ts --phase=publish",
    "demo:sunny-investor:v21:add-bgm": "tsx scripts/sunny-shutter-investor-demo-v21.ts --phase=add-bgm",
    "demo:sunny-investor:v21:resume": "bash scripts/sunny-shutter-investor-demo-v21-resume.sh",
    "e2e:phase4:mock": "node --import tsx --test tests/personal-status-customer-safe.test.ts tests/personal-customer-strings.test.ts tests/unified-creative-strategist.test.ts tests/seedance-privacy-fallback.test.ts",
    "mode:check": "tsx scripts/check-real-mode.ts",
    "mode:check:strict": "tsx scripts/check-real-mode.ts -- --strict",
    "roadmap": "tsx scripts/roadmap.ts",
    "test": "node --import tsx --test tests/**/*.test.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@prisma/client": "^6.19.3",
    "@tanstack/react-virtual": "^3.14.6",
    "@vercel/blob": "^2.6.1",
    "@volcengine/tos-sdk": "^2.9.1",
    "apify-client": "^2.23.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.10",
    "next-auth": "^4.24.14",
    "next-themes": "^0.4.6",
    "openai": "^6.46.0",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.2",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "stripe": "^17.7.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "puppeteer-core": "^25.2.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
