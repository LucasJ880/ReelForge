# ====== 必填 ======
#
# 这份 .env.example 描述的是「海外部署默认路径」：Vercel + Neon + OpenAI + Vercel Blob。
#
# 如果你要部署中国大陆版本，**不要在这份文件填**，而是参考 `.env.china.example`：
#   AI_PROVIDER=volcengine
#   STORAGE_PROVIDER=volcengine_tos
#   VIDEO_PROVIDER=volcengine
# 业务代码通过 provider 抽象层根据这三个变量切换；两套配置互不影响。

# === Provider 路由（可选；不设置时默认走 openai / vercel_blob / volcengine 视频） ===
# AI_PROVIDER=openai            # openai | volcengine
# STORAGE_PROVIDER=vercel_blob  # vercel_blob | volcengine_tos
# VIDEO_PROVIDER=volcengine     # volcengine（即梦/Seedance；当前唯一实现）
# REGION=global                 # global | cn
# DEPLOYMENT_TARGET=vercel      # vercel | china

# Neon Postgres
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# OpenAI（文案/调研/打分/蒸馏的 LLM 管线）
OPENAI_API_KEY=sk-your-openai-api-key-here
# 旧版兜底变量；只对未单独配置 tier 的阶段生效。建议改用下面的分层变量。
OPENAI_MODEL=gpt-4o-mini

# === OpenAI 模型分层（2026-05 起强烈建议） ===
# director / script / videoPrompt：用户最终看到的视频脚本 / Seedance prompt / 完整 DirectorPlan
# 这三个 tier 不会退到 mini 模型；fallback chain: gpt-5.5 → gpt-4.1 → gpt-4o
OPENAI_DIRECTOR_MODEL=gpt-5.5
OPENAI_SCRIPT_MODEL=gpt-5.5
OPENAI_VIDEO_PROMPT_MODEL=gpt-5.5
# creative：客户能看到的创意方向/角度
OPENAI_CREATIVE_MODEL=gpt-4.1
# qa：AI 初审 / Reviewer Agent → 推理能力优先
OPENAI_QA_MODEL=gpt-4.1-mini
# fast：分类 / 抽取 / 轻量补字段（仅这一档可用 mini）
OPENAI_FAST_MODEL=gpt-4o-mini
# research：市场调研结构化压缩
OPENAI_RESEARCH_MODEL=gpt-4o-mini
# vision：图像分析（暂只 gpt-4o 支持 JSON + image，谨慎覆盖）
OPENAI_VISION_MODEL=gpt-4o
# OpenAI 文生图（Logo 生成 / Image 2）
OPENAI_IMAGE_MODEL=gpt-image-1
# 强制 logo / image 走 mock（跳过真实 OpenAI 额度，用于测试和演示）
IMAGE_ENGINE_MOCK=false

# === LLM mock 开关（推荐统一用 LLM_FORCE_MOCK） ===
# LLM_FORCE_MOCK=true 时 director / wizard-script / videoPrompt 等所有 service
# 都跳过真 OpenAI 调用，走自家 mock 输出（QA / staging / 演示）。
# 任何漏掉自家 mock 短路的 service 调到 chatJson/chatJsonByTier 时会立刻抛错，
# 防止悄悄消耗 OpenAI 额度。
LLM_FORCE_MOCK=false
# 向后兼容别名（任一为 true 都等价于 LLM_FORCE_MOCK=true）：
#   DIRECTOR_FORCE_MOCK=true   # 只影响 director-service
#   SCRIPT_FORCE_MOCK=true     # 只影响 wizard-script-service

# NextAuth（JWT 密钥，生成: openssl rand -hex 32）
AUTH_SECRET=

# Vercel Blob（视频/图片/CSV 存储）
# 硬要求：缺该 token 时 stitch-service / openai-image 会直接 throw，
#         不再静默回退到 file:// / data:image/png;base64 写库。
BLOB_READ_WRITE_TOKEN=your-vercel-blob-rw-token

# 应用公网地址
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ====== 视频生成：即梦 / 火山方舟 Seedance ======
# 未填时走 mock（不消耗真实 Token，用于开发测试）
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# T2V 模型
ARK_VIDEO_MODEL=doubao-seedance-2-0-260128
# I2V 模型（与 T2V 可相同或不同，留空则复用 ARK_VIDEO_MODEL）
ARK_VIDEO_I2V_MODEL=

# ====== 数字人对口型：火山引擎 OmniHuman（智能视觉服务 / Visual CV） ======
# 用「一张模特图 + 一段中文配音」生成真正对口型的数字人讲解视频。
# 走的是「智能视觉服务」(visual.volcengineapi.com)，鉴权用火山主账号/子账号 AK/SK
# （复用下面 TOS 同一套 VOLCENGINE_ACCESS_KEY_ID / _SECRET_ACCESS_KEY），
# 不是 ARK_API_KEY，也不是上面的 TTS 凭证。
# 开通路径：火山引擎控制台 → 智能视觉服务 → 开通 + 申请 OmniHuman 使用权限。
# 端到端脚本：npm run demo:omnihuman（依赖先跑 demo:store-ad:keyframes + demo:store-ad:vo）。
#
# 火山 AK/SK（与 TOS 共用；申请：https://console.volcengine.com/iam/keymanage）
# VOLCENGINE_ACCESS_KEY_ID=
# VOLCENGINE_SECRET_ACCESS_KEY=
# OmniHuman 算法名（req_key）：不同账号开通的版本取值不同（1.0 quick / 1.5 …），
# 跑真实任务前请在控制台「OmniHuman → 调用步骤2:视频生成」或 API Explorer 核对后填写。
# VOLC_OMNIHUMAN_REQ_KEY=realman_avatar_picture_omni_v2
# 可选：覆盖 Visual 服务接入点（一般无需改）
# VOLC_VISUAL_HOST=visual.volcengineapi.com
# VOLC_VISUAL_REGION=cn-north-1
# VOLC_VISUAL_SERVICE=cv
# VOLC_VISUAL_VERSION=2022-08-31

# ====== 中文口播旁白：火山「大模型语音合成」（豆包语音） ======
# 独立于 Ark 的服务（走 openspeech.bytedance.com）。开通路径：
#   火山引擎控制台 → 语音技术 → 语音合成大模型 → 创建应用，拿 AppID / Access Token。
# 注意：正式版需对所选音色「0 元下单」完成授权，否则报 access denied。
#
# 凭证（二选一）：新版控制台用 API Key；旧版用 AppID + Access Token。
VOLC_TTS_APPID=
VOLC_TTS_ACCESS_TOKEN=
# VOLC_TTS_API_KEY=            # 新版控制台 API Key（可替代上面两个，仅 V3）
#
# 版本/计费资源 ID：
#   seed-tts-2.0（默认，推荐）→ 2.0 预置音色 *_uranus_bigtts，最像真人，走 V3 流式接口
#   seed-icl-2.0              → 声音复刻（克隆音色，speaker 为 S_xxx），走 V3，自动带 model_type=4
#   留空 / 非 seed- 开头        → 1.0 音色 *_mars_bigtts/*_moon_bigtts，走 V1 接口
VOLC_TTS_RESOURCE_ID=seed-tts-2.0
# 音色 ID（speaker）。
#   预置 2.0 女声：邻家女孩 zh_female_linjianvhai_uranus_bigtts（首选）/
#                爽快思思 zh_female_shuangkuaisisi_uranus_bigtts / Vivi zh_female_vv_uranus_bigtts
#   声音复刻：填克隆得到的 Speaker ID（S_xxxxx），并把 VOLC_TTS_RESOURCE_ID 设为 seed-icl-2.0
VOLC_TTS_VOICE_TYPE=zh_female_linjianvhai_uranus_bigtts
# V1 集群（仅 1.0 音色用）
VOLC_TTS_CLUSTER=volcano_tts
# 可选：语速。V1 倍率（1.05~1.15）/ V3 速率档位[-50,100]
# VOLC_TTS_SPEED=1.08
# VOLC_TTS_SPEECH_RATE=12
# 可选：覆盖接口地址
# VOLC_TTS_ENDPOINT_V3=https://openspeech.bytedance.com/api/v3/tts/unidirectional
# VOLC_TTS_ENDPOINT_V1=https://openspeech.bytedance.com/api/v1/tts

# 强制所有视频走 mock（跳过真实 AI 额度）
#
# ⚠️  Phase 4 安全约定（2026-05+）：
#   - dev (.env.local) 强烈建议显式设为 true，避免 npm run dev 默认烧真钱。
#     `npm run mode:check` 会在 predev 时打印当前模式；任何 REAL 都要主动确认。
#   - staging / prod 才显式设 false。
#   - 如果忘了设：当 ARK_API_KEY 已配置但 VIDEO_ENGINE_MOCK 未设 → isMockMode() 返回
#     false → 真烧 Seedance。这是**已知静默扣费陷阱**。
VIDEO_ENGINE_MOCK=false
# 生成任务全局 deadline（分钟）。超过 deadline + 宽限仍非终态 → watchdog 判 FAILED(timeout)
VIDEO_JOB_DEADLINE_MIN=10
# watchdog 信号 A 宽限期（分钟），默认 2
# WATCHDOG_GRACE_MIN=2
# watchdog 信号 B：provider 报 running 但 updated_at 从未推进超过 N 分钟 → provider_stalled
# PROVIDER_STALL_MIN=8
# Seedance HTTP 显式超时（毫秒），默认 30000
# SEEDANCE_HTTP_TIMEOUT_MS=30000
# 连续 N 次 Provider 状态查询失败后 → VideoJob 标记 FAILED 并提供重试入口
SEEDANCE_POLL_ERROR_THRESHOLD=3
# 生成入口熔断（最近窗口僵死率超阈值时拒绝新任务，半开探测自动恢复）
# DISPATCH_BREAKER_ENABLED=true
# DISPATCH_BREAKER_WINDOW_MIN=60
# DISPATCH_BREAKER_STALL_RATE=0.8
# DISPATCH_BREAKER_MIN_SAMPLES=3

# ====== Phase 7a — 用户配额 ======
# production 默认强制限额；dev 默认关闭（不影响 walkthrough:mock）
# QUOTA_ENFORCE=true
# 免费档限额见 src/lib/config/quota-tiers.ts

# ====== Cron & 初始化 ======
# Cron 密钥（Vercel Cron 调用时验证）
CRON_SECRET=

# 首次部署种子管理员账号（只有首次 seed 生效）
SEED_ADMIN_EMAIL=admin@aivora.internal
SEED_ADMIN_PASSWORD=

# ====== 真实市场调研：Apify TikTok Scraper ======
# 未填时 discovery-service 仅走 LLM 常识模式
# 已填时会真实抓 TikTok 高赞视频 + 热评，喂给 LLM 作为上下文 → 更可信的 pain_points
APIFY_TOKEN=
# 可选 Actor 覆盖（默认 clockworks/tiktok-scraper + clockworks/tiktok-comments-scraper）
APIFY_TIKTOK_SEARCH_ACTOR=
APIFY_TIKTOK_VIDEO_ACTOR=
APIFY_TIKTOK_COMMENTS_ACTOR=

# ====== TikTok OAuth（V2 全自动发布预留；MVP 半自动不使用） ======
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ====== 客户 Demo：数字人 Provider（默认 mock；拿到 HeyGen key 后切换） ======
DIGITAL_HUMAN_PROVIDER=mock
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=

# ====== 可选：I2V 抠图预处理（V2） ======
# 若填写，则 I2V 参考图上传后自动走抠图/白底处理
REMOVE_BG_API_KEY=

# ====== i18n ======
# 默认语言（zh-CN 或 en-US；用户可在 sidebar 切换并写入 cookie + localStorage 持久化）
NEXT_PUBLIC_DEFAULT_LOCALE=zh-CN

# ====== 多段视频拼接（30s/60s 流程） ======
# 是否启用 FFmpeg 后端拼接（false 时多段视频会被当作 mock，不真实拼接，仅 UI 可演示）
ENABLE_VIDEO_STITCHING=true

# 拼接 runtime 模式（2026-05 重构后）：
#   external — 委托给 GitHub Action runner 跑 ffmpeg + 上传 Blob（默认；生产必选，
#              因为 Vercel Serverless 没有 ffmpeg 二进制）
#   local    — 在本进程 spawn ffmpeg 直接拼接（仅 dev / 手动脚本场景）
# 未设置时：NODE_ENV=production → external；否则 → local
# 生产 Vercel 必须设置或保持默认（external），否则函数运行时会因 ENOENT 失败。
STITCH_RUNTIME=external
