# 数据库 (Neon Postgres)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# 即梦 / 火山方舟 (Seedance)
ARK_API_KEY=your-ark-api-key-here
