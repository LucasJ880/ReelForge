{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "reelforge://schemas/video_job",
  "title": "Video Generation Job",
  "description": "视频生成任务 — 支持多 provider 调度、状态流转、成本追踪",
  "type": "object",
  "properties": {
    "job_id": {"type": "string"},
    "project_id": {"type": "string"},
    "script_id": {"type": "string"},
    "provider": {"type": "string", "enum": ["mock", "seedance", "runway", "pika"]},
    "model": {"type": "string", "description": "Provider 使用的具体模型（如 mock-v1, seedance-1.0）"},
    "status": {
      "type": "string",
      "enum": ["pending", "processing", "completed", "failed", "retrying", "timeout", "cancelled"]
    },
    "input_params": {
      "type": "object",
      "properties": {
        "prompt": {"type": "string"},
        "duration_seconds": {"type": "integer"},
        "aspect_ratio": {"type": "string"},
        "style": {"type": "string"},
        "voice_id": {"type": "string"},
        "music_url": {"type": "string"}
      }
    },
    "output_url": {"type": ["string", "null"]},
    "output_metadata": {
      "type": "object",
      "properties": {
        "resolution": {"type": "string"},
        "file_size_bytes": {"type": "integer"},
        "duration": {"type": "number", "description": "实际视频时长（秒）"},
        "format": {"type": "string"},
        "aspect_ratio": {"type": "string"},
        "style": {"type": "string"},
        "prompt_length": {"type": "integer"}
      }
    },
    "duration_requested": {"type": "integer", "description": "请求的目标时长（秒）"},
    "aspect_ratio": {"type": "string", "default": "9:16"},
    "retry_count": {"type": "integer", "default": 0},
    "max_retries": {"type": "integer", "default": 3},
    "attempt_count": {"type": "integer", "default": 1, "description": "实际尝试次数"},
    "error_message": {"type": ["string", "null"]},
    "cost_cents": {"type": "integer", "description": "实际成本（美分）"},
    "estimated_cost_cents": {"type": "integer", "description": "预估成本（美分）"},
    "started_at": {"type": ["string", "null"], "format": "date-time"},
    "completed_at": {"type": ["string", "null"], "format": "date-time"},
    "processing_time_ms": {"type": "integer", "description": "处理耗时（毫秒）"},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "agent_version": {"type": "string"}
  },
  "required": ["job_id", "script_id", "provider", "status"]
}
