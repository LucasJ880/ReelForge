# Aivora · Docker 构建排除
# 与 .gitignore 大体一致，但额外排除一些 build 中不需要的产物

# 依赖
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Next.js
.next
out
build

# 测试
coverage
*.tsbuildinfo

# 环境变量（绝不进镜像）
.env
.env.*
!.env.example
!.env.china.example
!.env.production.example

# Git / IDE
.git
.gitignore
.gitattributes
.vscode
.idea
.DS_Store
*.pem

# Vercel
.vercel
.vercelignore
vercel.json

# 本地视频/截图产物
tmp
logs
/public/generated
/public/brand

# Legacy
_legacy

# Docs / scripts not needed at runtime
docs
.cursor
*.md
!README.md

# Cursor 相关
ai-context/repo-map.json
