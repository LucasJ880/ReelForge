# ====== 必填 ======

# Neon Postgres
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# OpenAI（文案/调研/打分/蒸馏的 LLM 管线）
OPENAI_API_KEY=sk-your-openai-api-key-here
# 旧版兜底变量；只对未单独配置 tier 的阶段生效。建议改用下面的分层变量。
OPENAI_MODEL=gpt-4o-mini

# === OpenAI 模型分层（2026-05 起强烈建议） ===
# director / script / videoPrompt：用户最终看到的视频脚本 / Seedance prompt / 完整 DirectorPlan
# 这三个 tier 不会退到 mini 模型；fallback chain: gpt-5.5 → gpt-4.1 → gpt-4o
OPENAI_DIRECTOR_MODEL=gpt-5.5
OPENAI_SCRIPT_MODEL=gpt-5.5
OPENAI_VIDEO_PROMPT_MODEL=gpt-5.5
# creative：客户能看到的创意方向/角度
OPENAI_CREATIVE_MODEL=gpt-4.1
# qa：AI 初审 / Reviewer Agent → 推理能力优先
OPENAI_QA_MODEL=gpt-4.1-mini
# fast：分类 / 抽取 / 轻量补字段（仅这一档可用 mini）
OPENAI_FAST_MODEL=gpt-4o-mini
# research：市场调研结构化压缩
OPENAI_RESEARCH_MODEL=gpt-4o-mini
# vision：图像分析（暂只 gpt-4o 支持 JSON + image，谨慎覆盖）
OPENAI_VISION_MODEL=gpt-4o
# OpenAI 文生图（Logo 生成 / Image 2）
OPENAI_IMAGE_MODEL=gpt-image-1
# 强制 logo / image 走 mock（跳过真实 OpenAI 额度，用于测试和演示）
IMAGE_ENGINE_MOCK=false

# === LLM mock 开关（推荐统一用 LLM_FORCE_MOCK） ===
# LLM_FORCE_MOCK=true 时 director / wizard-script / videoPrompt 等所有 service
# 都跳过真 OpenAI 调用，走自家 mock 输出（QA / staging / 演示）。
# 任何漏掉自家 mock 短路的 service 调到 chatJson/chatJsonByTier 时会立刻抛错，
# 防止悄悄消耗 OpenAI 额度。
LLM_FORCE_MOCK=false
# 向后兼容别名（任一为 true 都等价于 LLM_FORCE_MOCK=true）：
#   DIRECTOR_FORCE_MOCK=true   # 只影响 director-service
#   SCRIPT_FORCE_MOCK=true     # 只影响 wizard-script-service

# NextAuth（JWT 密钥，生成: openssl rand -hex 32）
AUTH_SECRET=

# Vercel Blob（视频/图片/CSV 存储）
# 硬要求：缺该 token 时 stitch-service / openai-image 会直接 throw，
#         不再静默回退到 file:// / data:image/png;base64 写库。
BLOB_READ_WRITE_TOKEN=your-vercel-blob-rw-token

# 应用公网地址
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ====== 视频生成：即梦 / 火山方舟 Seedance ======
# 未填时走 mock（不消耗真实 Token，用于开发测试）
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# T2V 模型
ARK_VIDEO_MODEL=doubao-seedance-2-0-260128
# I2V 模型（与 T2V 可相同或不同，留空则复用 ARK_VIDEO_MODEL）
ARK_VIDEO_I2V_MODEL=

# 强制所有视频走 mock（跳过真实 AI 额度）
#
# ⚠️  Phase 4 安全约定（2026-05+）：
#   - dev (.env.local) 强烈建议显式设为 true，避免 npm run dev 默认烧真钱。
#     `npm run mode:check` 会在 predev 时打印当前模式；任何 REAL 都要主动确认。
#   - staging / prod 才显式设 false。
#   - 如果忘了设：当 ARK_API_KEY 已配置但 VIDEO_ENGINE_MOCK 未设 → isMockMode() 返回
#     false → 真烧 Seedance。这是**已知静默扣费陷阱**。
VIDEO_ENGINE_MOCK=false
# 视频生成「用时较长」阈值（分钟）；超过后 UI 提示用户可刷新/重试，但不会自动判失败
SEEDANCE_TIMEOUT_MIN=15
# 连续 N 次 Provider 状态查询失败后 → VideoJob 标记 FAILED 并提供重试入口
SEEDANCE_POLL_ERROR_THRESHOLD=3
# 可选：Seedance webhook 回调地址（公网可达）。未填则只走轮询
# 例：https://your-app.vercel.app/api/webhooks/seedance
SEEDANCE_CALLBACK_URL=

# ====== Phase 7a — 用户配额 ======
# production 默认强制限额；dev 默认关闭（不影响 walkthrough:mock）
# QUOTA_ENFORCE=true
# 免费档限额见 src/lib/config/quota-tiers.ts

# ====== Cron & 初始化 ======
# Cron 密钥（Vercel Cron 调用时验证）
CRON_SECRET=

# 首次部署种子管理员账号（只有首次 seed 生效）
SEED_ADMIN_EMAIL=admin@aivora.internal
SEED_ADMIN_PASSWORD=

# ====== 真实市场调研：Apify TikTok Scraper ======
# 未填时 discovery-service 仅走 LLM 常识模式
# 已填时会真实抓 TikTok 高赞视频 + 热评，喂给 LLM 作为上下文 → 更可信的 pain_points
APIFY_TOKEN=
# 可选 Actor 覆盖（默认 clockworks/tiktok-scraper + clockworks/tiktok-comments-scraper）
APIFY_TIKTOK_SEARCH_ACTOR=
APIFY_TIKTOK_VIDEO_ACTOR=
APIFY_TIKTOK_COMMENTS_ACTOR=

# ====== TikTok OAuth（V2 全自动发布预留；MVP 半自动不使用） ======
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ====== 客户 Demo：数字人 Provider（默认 mock；拿到 HeyGen key 后切换） ======
DIGITAL_HUMAN_PROVIDER=mock
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=

# ====== 可选：I2V 抠图预处理（V2） ======
# 若填写，则 I2V 参考图上传后自动走抠图/白底处理
REMOVE_BG_API_KEY=

# ====== i18n ======
# 默认语言（zh-CN 或 en-US；用户可在 sidebar 切换并写入 cookie + localStorage 持久化）
NEXT_PUBLIC_DEFAULT_LOCALE=zh-CN

# ====== 多段视频拼接（30s/60s 流程） ======
# 是否启用 FFmpeg 后端拼接（false 时多段视频会被当作 mock，不真实拼接，仅 UI 可演示）
ENABLE_VIDEO_STITCHING=true

# 拼接 runtime 模式（2026-05 重构后）：
#   external — 委托给 GitHub Action runner 跑 ffmpeg + 上传 Blob（默认；生产必选，
#              因为 Vercel Serverless 没有 ffmpeg 二进制）
#   local    — 在本进程 spawn ffmpeg 直接拼接（仅 dev / 手动脚本场景）
# 未设置时：NODE_ENV=production → external；否则 → local
# 生产 Vercel 必须设置或保持默认（external），否则函数运行时会因 ENOENT 失败。
STITCH_RUNTIME=external
