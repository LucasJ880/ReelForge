# 生产环境必填（在 Vercel Dashboard 的 Environment Variables 里逐项添加）

DATABASE_URL=
AUTH_SECRET=
NEXTAUTH_URL=
NEXT_PUBLIC_APP_URL=
BLOB_READ_WRITE_TOKEN=
CRON_SECRET=
GITHUB_STITCH_DISPATCH_TOKEN=
# Vercel 自动提供 repository/ref；自托管环境才需要显式填写
# GITHUB_STITCH_REPOSITORY=LucasJ880/ReelForge
# GITHUB_STITCH_REF=main

SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-2
PRODUCT_IMAGE_RATE_LIMIT_PER_HOUR=5
# 验证/预览环境设 true；生产留空或 false 后只由用户主动触发真实图片调用
IMAGE_ENGINE_MOCK=true

BYTEPLUS_ARK_API_KEY=
ARK_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
ARK_VIDEO_MODEL=dreamina-seedance-2-0-260128
ARK_VIDEO_I2V_MODEL=
VIDEO_ENGINE_MOCK=true
CONTENT_REVIEW_ENABLED=false
CONTENT_REVIEW_PROVIDER=openai_moderation
CONTENT_REVIEW_MOCK=true
AI_DISCLOSURE_END_CARD_ENABLED=false
NEXT_PUBLIC_PRIVACY_EMAIL=
# Buddy API Vercel secret name（本轮不启用真实调用）
shuyu_api_key=

APIFY_TOKEN=
APIFY_TIKTOK_VIDEO_ACTOR=

# 可选
REMOVE_BG_API_KEY=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
