{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "reelforge://schemas/qa_report",
  "title": "QA Report",
  "description": "视频质检报告",
  "type": "object",
  "properties": {
    "report_id": {"type": "string"},
    "video_job_id": {"type": "string"},
    "project_id": {"type": "string"},
    "scores": {
      "type": "object",
      "properties": {
        "overall": {"type": "number", "minimum": 0, "maximum": 100},
        "visual": {"type": "number", "minimum": 0, "maximum": 100},
        "audio": {"type": "number", "minimum": 0, "maximum": 100},
        "content": {"type": "number", "minimum": 0, "maximum": 100},
        "technical": {"type": "number", "minimum": 0, "maximum": 100}
      },
      "required": ["overall"]
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {"type": "string", "enum": ["visual", "audio", "content", "technical", "branding"]},
          "severity": {"type": "string", "enum": ["critical", "major", "minor", "info"]},
          "description": {"type": "string"},
          "timestamp": {"type": "string"},
          "suggestion": {"type": "string"}
        },
        "required": ["type", "severity", "description"]
      }
    },
    "suggestions": {"type": "array", "items": {"type": "string"}},
    "auto_pass": {"type": "boolean", "description": "自动质检是否通过"},
    "auto_pass_threshold": {"type": "number", "default": 70},
    "human_review": {
      "type": "object",
      "properties": {
        "status": {"type": "string", "enum": ["pending", "approved", "rejected"]},
        "reviewer": {"type": "string"},
        "notes": {"type": "string"},
        "reviewed_at": {"type": "string", "format": "date-time"}
      }
    },
    "created_at": {"type": "string", "format": "date-time"}
  },
  "required": ["report_id", "video_job_id", "project_id", "scores", "auto_pass"]
}
